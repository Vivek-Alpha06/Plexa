# Copy to `.env` (cp .env.example .env). These are the live public TESTNET
# contract ids — no secrets — so the app runs against testnet out of the box.
#
# Prefer a zero-setup run? Set VITE_DEMO=true for a fully local, in-memory
# demo (no wallet, no network required).
VITE_DEMO=false

VITE_NETWORK=testnet
VITE_RPC_URL=https://soroban-testnet.stellar.org
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Plexa v5 testnet deployment (real Soroswap liquidation).
